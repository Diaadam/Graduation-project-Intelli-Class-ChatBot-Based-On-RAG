  {
    "type": "ListItem",
    "element_id": "74779a0af41025f9594e9e2467b40c0c",
    "text": "Cyber-physical systems integrate physical dynamics and computational systems, so they commonly combine both discrete and continuous dynamics.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            149.28201751734377
          ],
          [
            46.38302830504534,
            238.3484168
          ],
          [
            652.9668215141677,

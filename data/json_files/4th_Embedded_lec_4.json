  {
    "type": "ListItem",
    "element_id": "14974f81f9901c71af4d16a535ea57d8",
    "text": "Consider a thermostat modeled as a state machine with states = {heating; cooling}, shown in Figure.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            149.28201751734377
          ],
          [
            46.38302830504534,
            208.34841339999997
          ],
          [
            650.9990143499382,
            208.34841339999997
          ],
          [
            650.9990143499382,
            149.28201751734377
          ]
        ],
        "system": "PixelSpace",
        "layout_width": 720.0,
        "layout_height": 540.0
      },
      "file_directory": "data\\raw\\Embedded",
      "filename": "Lec 4.pdf",
      "languages": [
        "eng"

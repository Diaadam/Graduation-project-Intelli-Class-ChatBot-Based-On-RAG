    }
  },
  {
    "type": "ListItem",
    "element_id": "67fad0dd6d35daa8b28121a3456acd6f",
    "text": "The input is a continuous-time signal \u01ac : R (cid:0) R where \u01ac(t) represents the temperature at time t. \u2022 The initial state is cooling, and the transition out of this state is enabled at the earliest time t after the start time when \u01ac(t) \u2264 18.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            149.28201751734377
          ],
          [
            46.38302830504534,
            308.84841324
          ],
          [
            628.1768823956735,
            308.84841324
          ],
          [
            628.1768823956735,
            149.28201751734377
          ]
        ],
        "system": "PixelSpace",
        "layout_width": 720.0,
        "layout_height": 540.0
      },
      "file_directory": "data\\raw\\Embedded",
      "filename": "Lec 4.pdf",
      "languages": [
        "eng"
      ],
      "last_modified": "2021-04-13T13:58:32",
      "page_number": 7,
      "parent_id": "606f5fde43fd0576f62740645b3b9b73",
      "filetype": "application/pdf"
    }
  },
  {
    "type": "ListItem",
    "element_id": "510c42d61c28eb51991ef9379c665e23",
    "text": "In this example, we assume the outputs are pure signals {heatOn and heatOff}.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            320.28202895734375
          ],
          [
            46.38302830504534,
            379.34843484
          ],
          [
            627.5889924893994,
            379.34843484
          ],
          [
            627.5889924893994,
            320.28202895734375
          ]
        ],
        "system": "PixelSpace",
        "layout_width": 720.0,
        "layout_height": 540.0
      },
      "file_directory": "data\\raw\\Embedded",
      "filename": "Lec 4.pdf",
      "languages": [
        "eng"

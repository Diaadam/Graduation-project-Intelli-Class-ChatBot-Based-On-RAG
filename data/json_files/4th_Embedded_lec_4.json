      "last_modified": "2021-04-13T13:58:32",
      "page_number": 6,
      "parent_id": "606f5fde43fd0576f62740645b3b9b73",
      "filetype": "application/pdf"
    }
  },
  {
    "type": "UncategorizedText",
    "element_id": "26e771395720879dfa64be295f781fd3",
    "text": "Cont.,",
    "metadata": {
      "coordinates": {
        "points": [
          [
            56.698818,
            62.56259899999998
          ],
          [
            56.698818,
            106.56259899999998

          [
            162.89998967999998,
            106.56259899999998
          ],
          [
            162.89998967999998,
            62.56259899999998
          ]
        ],
        "system": "PixelSpace",
        "layout_width": 720.0,
        "layout_height": 540.0
      },
      "file_directory": "data\\raw\\Embedded",
      "filename": "Lec 4.pdf",
      "languages": [
        "eng"

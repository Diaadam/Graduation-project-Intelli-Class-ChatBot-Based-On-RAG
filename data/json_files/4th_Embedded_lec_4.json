  {
    "type": "ListItem",
    "element_id": "dfb648e3f9f1026038e25561b13ae6d2",
    "text": "Suppose that instead of discrete outputs as in Example 1 we wish to produce a control signal whose value is 1 when the heat is on and 0 when the heat is off.",

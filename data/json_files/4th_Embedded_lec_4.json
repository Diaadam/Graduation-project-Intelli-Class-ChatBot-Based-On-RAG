  {
    "type": "ListItem",
    "element_id": "297255c935b3c591ef271783ef45561a",
    "text": "It is natural to think of a state machine as an actor, as illustrated in Figure",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            149.28201751734377
          ],
          [
            46.38302830504534,
            208.34841339999997
          ],
          [
            646.0262230048197,

  {
    "type": "ListItem",
    "element_id": "ed16b3c7bb8c78ce6e2c1c42c0e94f97",
    "text": "The environment is the closed painted track. \u2022 It could be described by an equation. \u2022 We will describe it indirectly below by means of a sensor that determines how far the vehicle is to Left or Right of the track.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            147.03201263734377
          ],
          [
            46.38302830504534,
            303.59841772000004
          ],
          [
            641.3523284275188,
            303.59841772000004
          ],
          [
            641.3523284275188,
            147.03201263734377

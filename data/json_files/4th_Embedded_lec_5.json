  {
    "type": "ListItem",
    "element_id": "011b9ec7aad12619978c7172b7880816",
    "text": "The array is perpendicular to the AGV body axis. \u2022 As the AGV passes over the track, the diode directly above the track generates more current than the other diodes. By comparing the magnitudes of the currents through the different diodes, the sensor estimates the displacement e(t) of the center of the array (hence, the center of the AGV) from the track.",
    "metadata": {
      "coordinates": {
        "points": [
          [
            46.38302830504534,
            149.28201751734377
          ],
          [

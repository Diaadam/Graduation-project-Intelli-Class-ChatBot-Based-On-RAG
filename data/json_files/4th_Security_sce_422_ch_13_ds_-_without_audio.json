    }
  },
  {
    "type": "ListItem",
    "element_id": "74b47c656eaeffb816589b84de404415",
    "text": "digital signature made by sender signing entire message or hash with private-key",
    "metadata": {
      "category_depth": 0,
      "file_directory": "data\\raw\\Security",

  },
  {
    "type": "ListItem",
    "element_id": "63894bb7592e68f12f83a71c58c1ada1",
    "text": "assumed receiver has sender\u2019s public-key",
    "metadata": {
      "category_depth": 0,
      "file_directory": "data\\raw\\Security",
      "filename": "SCE 422 CH 13 DS - without audio.pptx",
      "last_modified": "2025-01-15T14:22:43",

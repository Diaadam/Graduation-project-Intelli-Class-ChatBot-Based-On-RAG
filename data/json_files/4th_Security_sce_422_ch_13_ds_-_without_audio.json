      "parent_id": "ebfb9fe1a5ef6e8fe75d5d94f21c29cf"
    }
  },
  {
    "type": "ListItem",
    "element_id": "ae58760560ccff9c6239ef7a857a35f4",
    "text": "with 512-1024 bit security",
    "metadata": {
      "category_depth": 0,
      "file_directory": "data\\raw\\Security",
      "filename": "SCE 422 CH 13 DS - without audio.pptx",
      "last_modified": "2025-01-15T14:22:43",

    "element_id": "a8841f794f18efa34374e6aaae786f5c",
    "text": "creates a 320 bit signature",
    "metadata": {
      "category_depth": 0,
      "file_directory": "data\\raw\\Security",
      "filename": "SCE 422 CH 13 DS - without audio.pptx",
      "last_modified": "2025-01-15T14:22:43",
